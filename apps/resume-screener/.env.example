# AI Audit Ledger ingest endpoint (the API base URL + /audit/events)
AUDIT_INGEST_URL=https://<your-api-id>.execute-api.<your-region>.amazonaws.com/prod/audit/events

# Single-tenant write key (used by `decide`)
AUDIT_WRITE_KEY=<your-tenant-write-key>

# Multi-tenant: comma-separated write keys (used by `generate`).
# If unset, generate falls back to AUDIT_WRITE_KEY.
AUDIT_WRITE_KEYS=<wk-tenant-a-key>,<wk-tenant-b-key>,<wk-tenant-c-key>
